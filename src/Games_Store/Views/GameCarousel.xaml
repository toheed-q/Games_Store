<UserControl x:Class="Games_Store.Views.GameCarousel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="420" d:DesignWidth="1000"
             Focusable="True"
             KeyDown="OnKeyDown"
             MouseEnter="OnMouseEnterCarousel"
             MouseLeave="OnMouseLeaveCarousel">

    <UserControl.Resources>
        <!-- Gradient presets for card covers when no image is loaded -->
        <LinearGradientBrush x:Key="CardGradient1" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0f3460" Offset="0" />
            <GradientStop Color="#e94560" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="CardGradient2" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#1a1a2e" Offset="0" />
            <GradientStop Color="#4834d4" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="CardGradient3" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#2d132c" Offset="0" />
            <GradientStop Color="#c72c41" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="CardGradient4" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0a1931" Offset="0" />
            <GradientStop Color="#185adb" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="CardGradient5" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#1b1b2f" Offset="0" />
            <GradientStop Color="#e43f5a" Offset="1" />
        </LinearGradientBrush>

        <!-- Nav arrow button style -->
        <Style x:Key="CarouselNavButton" TargetType="Button">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="#44000000" CornerRadius="24"
                                BorderBrush="#33ffffff" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#88e94560" />
                                <Setter TargetName="bg" Property="BorderBrush" Value="#e94560" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#cce94560" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid ClipToBounds="True">
        <!-- The carousel canvas where cards are placed and animated -->
        <Canvas x:Name="CarouselCanvas" Height="380" />

        <!-- Left navigation button -->
        <Button Style="{StaticResource CarouselNavButton}"
                HorizontalAlignment="Left" VerticalAlignment="Center"
                Margin="12,0,0,0" Click="OnPrevClick">
            <TextBlock Text="&#xE76B;" FontFamily="Segoe MDL2 Assets"
                       FontSize="20" Foreground="White" />
        </Button>

        <!-- Right navigation button -->
        <Button Style="{StaticResource CarouselNavButton}"
                HorizontalAlignment="Right" VerticalAlignment="Center"
                Margin="0,0,12,0" Click="OnNextClick">
            <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets"
                       FontSize="20" Foreground="White" />
        </Button>

        <!-- Indicator dots -->
        <StackPanel x:Name="IndicatorPanel" Orientation="Horizontal"
                    HorizontalAlignment="Center" VerticalAlignment="Bottom"
                    Margin="0,0,0,8" />
    </Grid>
</UserControl>

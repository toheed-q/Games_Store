<Window x:Class="Games_Store.Views.CreateAdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="600" Width="440"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        MouseLeftButtonDown="OnTitleBarDrag">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="TitleBarBtn" TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Foreground" Value="#888" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#2a2a4a" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseTitleBarBtn" TargetType="Button" BasedOn="{StaticResource TitleBarBtn}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#e94560" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AuthTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#0f0f1a" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="CaretBrush" Value="White" />
            <Setter Property="BorderBrush" Value="#2a2a4a" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2,0" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#e94560" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AuthPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="#0f0f1a" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="CaretBrush" Value="White" />
            <Setter Property="BorderBrush" Value="#2a2a4a" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2,0" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#e94560" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#0f0f1a" CornerRadius="12"
            BorderBrush="#2a2a4a" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="30" ShadowDepth="0" Opacity="0.6" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Border Grid.Row="0" Background="#1a1a2e"
                    CornerRadius="12,12,0,0"
                    BorderBrush="#2a2a4a" BorderThickness="0,0,0,1">
                <Grid Margin="14,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE7FC;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="14" Foreground="#e94560"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="Games Store" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#aaa" VerticalAlignment="Center" />
                        <TextBlock Text=" — First Time Setup" FontSize="13"
                                   Foreground="#555" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center" Margin="0,0,-4,0">
                        <Button Style="{StaticResource TitleBarBtn}"
                                Content="&#xE921;" ToolTip="Minimize"
                                Click="BtnMinimize_Click" />
                        <Button Style="{StaticResource CloseTitleBarBtn}"
                                Content="&#xE8BB;" ToolTip="Close"
                                Click="BtnClose_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="36,20,36,30">
                <StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                        <TextBlock Text="&#xE7FC;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="30" Foreground="#e94560"
                                   VerticalAlignment="Center" Margin="0,0,10,0" />
                        <TextBlock Text="GAMES STORE" FontSize="22" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center" />
                    </StackPanel>

                    <TextBlock Text="First Time Setup" FontSize="13"
                               Foreground="#888" HorizontalAlignment="Center" Margin="0,0,0,6" />

                    <!-- Notice Banner -->
                    <Border Background="#1a1a2e" CornerRadius="8" Padding="14,10"
                            Margin="0,0,0,20" BorderBrush="#e9456033" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="4" CornerRadius="2" Background="#e94560" Margin="0,0,12,0" />
                            <TextBlock Text="No admin account found. Create one to get started. This screen will only appear once."
                                       FontSize="12" Foreground="#aaa" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Admin Username" Foreground="#aaa"
                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6" />
                    <TextBox Style="{StaticResource AuthTextBox}"
                             Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,14" />

                    <TextBlock Text="Password" Foreground="#aaa"
                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6" />
                    <PasswordBox x:Name="PwdPassword"
                                 Style="{StaticResource AuthPasswordBox}"
                                 Margin="0,0,0,14" />

                    <TextBlock Text="Confirm Password" Foreground="#aaa"
                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6" />
                    <PasswordBox x:Name="PwdConfirm"
                                 Style="{StaticResource AuthPasswordBox}"
                                 Margin="0,0,0,6" />

                    <Border Background="#1f0a0e" CornerRadius="6" Padding="12,8"
                            Margin="0,6,0,0" BorderBrush="#e9456055" BorderThickness="1"
                            Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Fill="#e94560"
                                     VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="{Binding ErrorMessage}"
                                       Foreground="#ff8095" FontSize="12" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Button x:Name="BtnCreate" Content="Create Admin Account" Click="BtnCreate_Click"
                            Height="44" FontSize="14" FontWeight="SemiBold"
                            Foreground="White" Cursor="Hand" BorderThickness="0"
                            Margin="0,18,0,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" CornerRadius="8">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#e94560" Offset="0" />
                                            <GradientStop Color="#c0392b" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Opacity" Value="0.88" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>

<UserControl x:Class="Games_Store.Views.PublicStore"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Games_Store.ViewModels"
             xmlns:views="clr-namespace:Games_Store.Views">
    <UserControl.DataContext>
        <vm:StoreViewModel />
    </UserControl.DataContext>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="20">

                <!-- Search Bar -->
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource SearchBoxStyle}"
                         Tag="Search for games..."
                         Margin="0,0,0,25" FontSize="16" Height="45" />

                <!-- Category Filter -->
                <TextBlock Text="CATEGORIES" FontSize="14" FontWeight="SemiBold"
                           Foreground="#666" Margin="0,0,0,10" />

                <ItemsControl ItemsSource="{Binding Categories}" Margin="0,0,0,25">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Name}"
                                    Command="{Binding DataContext.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding Name}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource CategoryButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="Foreground" Value="White" />
                                                <Setter Property="FontWeight" Value="Bold" />
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border CornerRadius="20"
                                                                    Padding="{TemplateBinding Padding}"
                                                                    BorderThickness="1.5" BorderBrush="#e94560"
                                                                    Margin="0,0,10,0">
                                                                <Border.Background>
                                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                        <GradientStop Color="#e94560" Offset="0" />
                                                                        <GradientStop Color="#c0392b" Offset="1" />
                                                                    </LinearGradientBrush>
                                                                </Border.Background>
                                                                <Border.Effect>
                                                                    <DropShadowEffect Color="#e94560" BlurRadius="18"
                                                                                      ShadowDepth="0" Opacity="0.45" />
                                                                </Border.Effect>
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Featured Games Carousel -->
                <TextBlock Text="FEATURED GAMES" FontSize="22" FontWeight="Bold"
                           Foreground="#e94560" Margin="0,0,0,10" />

                <views:GameCarousel GamesSource="{Binding CarouselGames}"
                                    GameSelected="OnCarouselGameSelected"
                                    Height="420" Margin="0,0,0,10" />

                <!-- All Games Section -->
                <TextBlock Text="ALL GAMES" FontSize="22" FontWeight="Bold"
                           Foreground="White" Margin="0,20,0,15" />

                <ItemsControl ItemsSource="{Binding AllGames}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#16213e" CornerRadius="10" Margin="0,0,15,15"
                                    Width="220" Cursor="Hand"
                                    MouseLeftButtonUp="OnGameCardClick">
                                <StackPanel>
                                    <Border CornerRadius="10,10,0,0" ClipToBounds="True" Height="140">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#1a1a2e" Offset="0" />
                                                <GradientStop Color="#0f3460" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Grid>
                                            <TextBlock Text="&#xE7FC;" FontFamily="Segoe MDL2 Assets"
                                                       FontSize="42" Foreground="#555"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            <Image Source="{Binding ImageUrl, Converter={StaticResource ImagePathConverter}}"
                                                   Stretch="UniformToFill" />
                                        </Grid>
                                    </Border>
                                    <StackPanel Margin="12,10,12,12">
                                        <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="Bold"
                                                   Foreground="White" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Genre}" FontSize="12"
                                                   Foreground="#888" Margin="0,3,0,5" />
                                        <TextBlock Text="{Binding Description}" FontSize="11"
                                                   Foreground="#aaa" TextWrapping="Wrap"
                                                   MaxHeight="34" TextTrimming="CharacterEllipsis" />
                                        <Grid Margin="0,8,0,0">
                                            <TextBlock Text="{Binding Price, StringFormat='${0:F2}'}"
                                                       FontSize="18" FontWeight="Bold"
                                                       Foreground="#4ecca3" />
                                            <Border Background="#e94560" CornerRadius="4"
                                                    Padding="8,3" HorizontalAlignment="Right"
                                                    Visibility="{Binding IsFeatured, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBlock Text="FEATURED" FontSize="9"
                                                           Foreground="White" FontWeight="Bold" />
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>


            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
